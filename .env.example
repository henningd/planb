APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
PORTAL_URL=https://portal.notfallhandbuch.eu

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE
APP_TIMEZONE=Europe/Berlin

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Kommagetrennte Adressen, die bei jeder Neu-Registrierung eine BCC-Info erhalten.
MAIL_REGISTER_BCC=

# 2FA-Pflicht für alle Nutzer ohne bestätigtes 2FA (true/false).
FEATURE_ENFORCE_2FA=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SEVENIO_API_KEY=
SEVENIO_SENDER=

# Stripe / Cashier (Mandanten-Abrechnung). Test-Mode-Keys aus dashboard.stripe.com.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=de_DE
# Stripe Price-IDs (im Stripe-Dashboard pro Plan/Intervall anlegen).
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_ADVANCED_MONTHLY=
STRIPE_PRICE_ADVANCED_YEARLY=
# Add-ons (Einmalzahlungen + Coaching-Retainer als Abo).
STRIPE_PRICE_ADDON_WORKSHOP=
STRIPE_PRICE_ADDON_COACHING_HOUR=
STRIPE_PRICE_ADDON_COACHING_RETAINER=
STRIPE_PRICE_ADDON_EXTRA_USER=

# Feature-Schalter (true/false). Standard: aktiv.
FEATURE_COMPLIANCE_ENABLED=true
FEATURE_DEPENDENCIES_ENABLED=true
FEATURE_INCIDENT_MODE_ENABLED=true
FEATURE_ROLES_ENABLED=true
FEATURE_PREVENTIVE_MEASURES_ENABLED=true
FEATURE_BIA_ENABLED=true
FEATURE_MATURITY_ENABLED=true
FEATURE_SUPPLY_CHAIN_RISK_ENABLED=true
FEATURE_BCM_POLICY_ENABLED=true
FEATURE_MANAGEMENT_REVIEW_ENABLED=true
FEATURE_TRAINING_RECORDS_ENABLED=true
FEATURE_BILLING_ENABLED=true

VITE_APP_NAME="${APP_NAME}"

# Kanonische Domain: 301-Redirect aller anderen Hosts (leer = deaktiviert)
CANONICAL_HOST=

# IndexNow-Schluessel (Bing & Co. sofort ueber URL-Aenderungen informieren; leer = aus)
INDEXNOW_KEY=
