<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <!-- Feature-Flags: alle Module für die Test-Suite zwingend aktiv,
             damit Tests unabhängig von der lokalen .env durchlaufen. -->
        <env name="FEATURE_COMPLIANCE_ENABLED" value="true" force="true"/>
        <env name="FEATURE_DEPARTMENTS_ENABLED" value="true" force="true"/>
        <env name="FEATURE_DEPENDENCIES_ENABLED" value="true" force="true"/>
        <env name="FEATURE_EMPLOYEE_GRAPH_TABS_ENABLED" value="true" force="true"/>
        <env name="FEATURE_INCIDENT_MODE_ENABLED" value="true" force="true"/>
        <env name="FEATURE_LESSONS_LEARNED_ENABLED" value="true" force="true"/>
        <env name="FEATURE_RISK_REGISTER_ENABLED" value="true" force="true"/>
        <env name="FEATURE_CONTRACTS_ENABLED" value="true" force="true"/>
        <env name="FEATURE_ROLES_ENABLED" value="true" force="true"/>
        <env name="FEATURE_MONITORING_API_ENABLED" value="true" force="true"/>
        <env name="FEATURE_PREVENTIVE_MEASURES_ENABLED" value="true" force="true"/>
        <env name="FEATURE_BIA_ENABLED" value="true" force="true"/>
        <env name="FEATURE_MATURITY_ENABLED" value="true" force="true"/>
        <env name="FEATURE_SUPPLY_CHAIN_RISK_ENABLED" value="true" force="true"/>
        <env name="FEATURE_BCM_POLICY_ENABLED" value="true" force="true"/>
        <env name="FEATURE_MANAGEMENT_REVIEW_ENABLED" value="true" force="true"/>
        <env name="FEATURE_TRAINING_RECORDS_ENABLED" value="true" force="true"/>
        <env name="FEATURE_BIBLE_VERSES_ENABLED" value="true" force="true"/>
        <!-- 2FA-Pflicht in der Test-Suite standardmäßig aus, damit bestehende
             Tests ohne 2FA-Setup auf geschützte Seiten kommen. Die gezielten
             Tests aktivieren sie per config(). -->
        <env name="FEATURE_ENFORCE_2FA" value="false" force="true"/>
    </php>
</phpunit>
